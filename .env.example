# =========================================================================
# AidoFor.me — copy to .env.local and fill in secrets.
# .env.local is gitignored. NEVER commit real keys or tokens.
# =========================================================================

# --- Supabase (shared with TutorPakar) ---------------------------------
# The Supabase project is shared with TutorPakar.com so one email and
# password works on both domains. Use the SAME values you already use
# for TutorPakar production.
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the new publishable key naming if Supabase has issued one for
# this project (it starts with "sb_publishable_"). Legacy JWT anon keys
# (NEXT_PUBLIC_SUPABASE_ANON_KEY) still work and are read as a fallback
# in lib/supabase/client.ts and lib/supabase/server.ts. Set only one.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required by the metered billing/provider gateway; never expose
# it through NEXT_PUBLIC_ or import it into a Client Component.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only provider credentials. The fixed-endpoint gateway fails closed
# when the credential for the database-approved route is absent.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=

# Stripe server credentials. Webhook signatures are checked against the raw
# request body before any payment fact reaches the credit ledger.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# A reviewed portal configuration that permits payment-method updates and
# cancellation, but not arbitrary plan/quantity changes.
STRIPE_PORTAL_CONFIGURATION_ID=

# Server-only secret used by the scheduled reconciliation endpoint.
CRON_SECRET=

# Optional operator identity recorded on provider-invoice imports.
AIDO_ADMIN_USER_ID=

# --- Canonical production URL ------------------------------------------
# Used by auth redirectTo links, email templates, and Open Graph. Must
# match the production hostname (no trailing slash).
# www.aidofor.me is canonical because Vercel Domains redirects the apex
# (aidofor.me) → www. Use the full https URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://www.aidofor.me

# --- Notes -------------------------------------------------------------
# - Never expose a Supabase service-role key here. It is NOT needed for
#   browser or server-side auth flows. If you ever need elevated access
#   for migrations, use a server-only secret outside the Next.js env.
# - Never prefix a secret key with NEXT_PUBLIC_. Doing so will ship it to
#   every browser bundle.
# - Do NOT change the Supabase "Site URL" globally — TutorPakar still
#   depends on it. Add AidoForMe URLs to "Additional Redirect URLs"
#   instead (see docs/shared-auth-setup.md).
